RewriteEngine On
RewriteBase /

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1%{REQUEST_URI} [R=301,L]

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# === Blog passthrough ===
RewriteRule ^blog - [L]

# === API Proxy - Try ProxyPass first ===
<IfModule mod_proxy.c>
  ProxyRequests Off
  ProxyPreserveHost On
  ProxyPass /api http://127.0.0.1:9000/api
  ProxyPassReverse /api http://127.0.0.1:9000/api
</IfModule>

# === Static files ===
RewriteRule ^sitemap\.xml$ sitemap.xml [L]
RewriteRule ^robots\.txt$ robots.txt [L]

# === Redirects ===
RewriteRule ^youtube-channel-name-ideas/?$ https://socialmelo.com/blog/english-youtube-channel-name-ideas/ [R=301,L]
RewriteRule ^instagram-bio-ideas/?$ https://socialmelo.com/blog/instagram-bio/ [R=301,L]
RewriteRule ^tiktok-username-ideas/?$ https://socialmelo.com/blog/tiktok-bio/ [R=301,L]
RewriteRule ^discord-server-names/?$ https://socialmelo.com/blog/discord-bio-template/ [R=301,L]
RewriteRule ^youtube-channel-ideas/?$ https://socialmelo.com/blog/water-youtube-channel-name/ [R=301,L]
RewriteRule ^social-media-bio-templates/?$ https://socialmelo.com/blog/aesthetic-bio-ideas/ [R=301,L]
RewriteRule ^content-creator-resources/?$ https://socialmelo.com/ [R=301,L]
RewriteRule ^influencer-guides/?$ https://socialmelo.com/ [R=301,L]
RewriteRule ^social-media-tips/?$ https://socialmelo.com/ [R=301,L]
RewriteRule ^channel-name-generator/?$ https://socialmelo.com/ [R=301,L]
RewriteRule ^profile-optimization/?$ https://socialmelo.com/ [R=301,L]

# === React Router ===
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/blog
RewriteCond %{REQUEST_URI} !^/api
RewriteRule ^ index.html [L,QSA]

# MIME types
<IfModule mod_mime.c>
  AddType application/xml .xml
  AddType text/plain .txt
  AddType application/javascript .js
  AddType text/css .css
</IfModule>

Options -Indexes
